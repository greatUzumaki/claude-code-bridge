# Copy to .env and edit. Used by docker-compose.yml. Do NOT commit .env.

# Postgres → postgres://app:app@localhost:5432/app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
POSTGRES_PORT=5432

# Redis → redis://:app@localhost:6379
REDIS_PASSWORD=app
REDIS_PORT=6379

# MinIO (S3) → API http://localhost:9000  Console http://localhost:9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Jaeger → UI http://localhost:16686  OTLP http://localhost:4318 (http) / :4317 (grpc)
JAEGER_UI_PORT=16686
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_OTLP_HTTP_PORT=4318
